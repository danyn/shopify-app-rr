<style>
  .nutrition-panel {
    min-height: 12px;
    border: 2px solid red;
  }
  pre {
    max-width: 600px;
    overflow: scroll;
  }
  .locale-debug {
    background: #f0f8ff;
    border: 2px solid #4a90e2;
    padding: 1rem;
    margin: 1rem 0;
    font-family: monospace;
    font-size: 14px;
  }
</style>

{% comment %} Language and Region Detection {% endcomment %}
<div class="locale-debug">
  <h4 style="margin: 0 0 0.5rem 0; color: #2c3e50;">🌍 Locale Detection</h4>
  
  {% if localization %}
    <div style="margin-bottom: 0.5rem;">
      <strong>Language:</strong> {{ localization.language.endonym_name | capitalize }} ({{ localization.language.iso_code }})
    </div>
    
    <div style="margin-bottom: 0.5rem;">
      <strong>Country:</strong> {{ localization.country.name }} ({{ localization.country.iso_code }})
    </div>
    
    <div style="margin-bottom: 0.5rem;">
      <strong>Available Languages:</strong> {{ localization.available_languages.size }}
    </div>
    
    <div style="margin-bottom: 0.5rem;">
      <strong>Available Countries:</strong> {{ localization.available_countries.size }}
    </div>
    
    {% comment %} Full JSON output for debugging {% endcomment %}
    <details style="margin-top: 0.5rem;">
      <summary style="cursor: pointer; color: #4a90e2;">View Full Localization Data</summary>
      <pre style="margin-top: 0.5rem; background: #fff; padding: 0.5rem; border-radius: 4px; overflow-x: auto;">
Language: {{ localization.language | json }}
Country: {{ localization.country | json }}
Available Languages: {{ localization.available_languages | json }}
Available Countries: {{ localization.available_countries | json }}
      </pre>
    </details>
  {% else %}
    <div style="color: #e74c3c;">
      ⚠️ Localization object not available
    </div>
  {% endif %}
</div>

