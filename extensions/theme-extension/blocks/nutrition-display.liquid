{% comment %} Get the nutrition panel metaobject reference {% endcomment %}
{% assign nutrition = product.metafields["$app"].nutrition_panel.value %}
{% assign test_boolen = product.metafields["$app:test"].boolean.value  %}

{% comment %} block.settings.nutrition_panel  product.metafields.app.nutrition_panel {% endcomment %}
{% if 'nutrition' %}
  <div
    class="nutrition-panel"
    style="padding: 1rem; border: 1px solid #e0e0e0; border-radius: 8px; margin: 1rem 0; background: #fff;"
  >

    <pre>
      <div> panel: {{ nutrition | json }}</div>
      <div> test bool: {{  test_boolen | json }}</div>
     
    </pre>
    <h3 style="margin: 0 0 0.75rem 0; font-size: 1.125rem; font-weight: 600;">
      {{ nutrition.name.value }}
    </h3>

    <div style="display: grid; gap: 0.5rem;">
      <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
        <span style="font-weight: 500;">{{ 'nutrition.panel.calories' | t }}</span>
        <span>{{ nutrition.calories.value }}</span>
      </div>

      <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0;">
        <span style="font-weight: 500;">{{ 'nutrition.panel.protein' | t }}</span>
        <span>{{ nutrition.protein.value }}{{ 'nutrition.panel.gramsUnit' | t }}</span>
      </div>

      <div style="display: flex; justify-content: space-between; padding: 0.5rem 0;">
        <span style="font-weight: 500;">{{ 'nutrition.panel.carbs' | t }}</span>
        <span>{{ nutrition.carbs.value }}{{ 'nutrition.panel.gramsUnit' | t }}</span>
      </div>
    </div>
  </div>
{% endif %}


