      "label": "Show announcement",
      "default": true
    },
    {
  "type": "metaobject",
  "id": "nutition_panel",
  "label": "Nutrition Panel",
  "metaobject_type": "app--276599242753--nutrition_panel"
  }
  ]
}
{% endschema %}

